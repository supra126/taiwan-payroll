{
  "name": "taiwan-payroll-mcp",
  "version": "1.4.0",
  "description": "台灣勞健保勞退計算 MCP server — 勞保、健保、勞退、補充保費、薪資扣繳、老年給付；支援 npx (stdio) 與遠端 Streamable HTTP。",
  "mcpName": "io.github.supra126/taiwan-payroll",
  "license": "MIT",
  "author": "supra126 <supra126@gmail.com>",
  "homepage": "https://github.com/supra126/taiwan-payroll/tree/main/packages/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supra126/taiwan-payroll.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/supra126/taiwan-payroll/issues"
  },
  "keywords": [
    "taiwan",
    "payroll",
    "mcp",
    "model-context-protocol",
    "勞保",
    "健保",
    "勞退",
    "薪資",
    "台灣"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "taiwan-payroll-mcp": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev:http": "wrangler dev",
    "deploy": "wrangler deploy",
    "set-url": "node scripts/set-remote-url.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29",
    "taiwan-payroll": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4"
  }
}
